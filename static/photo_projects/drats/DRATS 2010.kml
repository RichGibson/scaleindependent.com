			<Placemark>
				<name>Target 7 - Rim of Colton (I think)</name>
				<LookAt>
					<longitude>-111.6144331339667</longitude>
					<latitude>35.57266902277985</latitude>
					<altitude>0</altitude>
					<range>1079.698089906513</range>
